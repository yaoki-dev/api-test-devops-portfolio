{
  "name": "api-test-devops-portfolio",
  "private": true,
  "scripts": {
    "lint:md": "markdownlint '**/*.md' --ignore-path .markdownlintignore",
    "lint:md:fix": "markdownlint '**/*.md' --ignore-path .markdownlintignore --fix",
    "lint:text": "textlint '**/*.md' --ignore-path .textlintignore",
    "lint:text:fix": "textlint '**/*.md' --ignore-path .textlintignore --fix",
    "lint:links": "find . -name '*.md' -not -path './node_modules/*' -not -path './.venv/*' -not -path './claudedocs/*' -not -path './docs/tools/*' -not -path './docs/main/interview/*' -not -path './docs/main/6週プラン/*' -not -path './docs/analysis/*' -not -name 'DOCS_INDEX.md' | xargs -I {} markdown-link-check {} --config .markdown-link-check.json --quiet",
    "lint:links:verbose": "find . -name '*.md' -not -path './node_modules/*' -not -path './.venv/*' -not -path './claudedocs/*' -not -path './docs/tools/*' -not -path './docs/main/interview/*' -not -path './docs/main/6週プラン/*' -not -path './docs/analysis/*' -not -name 'DOCS_INDEX.md' | xargs -I {} markdown-link-check {} --config .markdown-link-check.json",
    "lint:all": "npm run lint:md && npm run lint:text",
    "lint:all:fix": "npm run lint:md:fix && npm run lint:text:fix"
  },
  "devDependencies": {
    "@mixedbread/mgrep": "^0.1.13",
    "@notprolands/ast-grep-mcp": "^1.1.1",
    "markdown-link-check": "^3.14.0",
    "markdownlint-cli": "^0.48.0",
    "textlint": "^15.6.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2"
  }
}
