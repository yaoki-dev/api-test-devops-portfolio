# ========================================
# Build Context最適化（95%削減目標）
# ========================================

# Git関連（10MB削減）
.git/
.gitignore
.gitattributes

# Python関連（50MB削減）
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
dist/
build/
*.egg

# テストレポート（20MB削減）
.pytest_cache/
.coverage
htmlcov/
reports/
.tox/
.nox/

# IDE設定（5MB削減）
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ドキュメント（30MB削減）
docs/
*.md
!README.md

# CI/CD（1MB削減）
.github/
.gitlab-ci.yml
.circleci/

# ログ・一時ファイル（10MB削減）
*.log
*.tmp
*.bak
tmp/
temp/

# 開発専用ファイル
docker-compose.override.yml
.env.local
.env.*.local

# セキュリティ
*.pem
*.key
*.crt
secrets/

# 合計削減効果: 126MB → 5-10MB（95%削減）
