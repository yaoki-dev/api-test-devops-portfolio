{
  "project": {
    "name": "api-test-devops-portfolio",
    "type": "python-testing-devops",
    "version": "1.0.0",
    "description": "APIテスト + DevOps 実践学習ポートフォリオ with Claude Flow integration"
  },
  "features": {
    "autoTopologySelection": true,
    "parallelExecution": true,
    "neuralTraining": true,
    "bottleneckAnalysis": true,
    "smartAutoSpawning": true,
    "selfHealingWorkflows": true,
    "crossSessionMemory": true,
    "githubIntegration": true,
    "sparcMethodology": true,
    "testDrivenDevelopment": true,
    "performanceMonitoring": true,
    "securityScanning": true
  },
  "performance": {
    "maxAgents": 15,
    "defaultTopology": "mesh",
    "executionStrategy": "adaptive",
    "tokenOptimization": true,
    "cacheEnabled": true,
    "telemetryLevel": "detailed",
    "parallelismLevel": 8,
    "resourceOptimization": true
  },
  "testing": {
    "framework": "pytest",
    "coverageThreshold": 85,
    "testTypes": ["unit", "integration", "security", "performance", "e2e"],
    "parallelTesting": true,
    "benchmarking": true,
    "loadTesting": true
  },
  "security": {
    "owaspCompliance": true,
    "staticAnalysis": ["bandit", "safety", "semgrep"],
    "vulnerabilityScanning": true,
    "securityTesting": true,
    "complianceChecks": true
  },
  "devops": {
    "containerization": "docker",
    "orchestration": "docker-compose",
    "cicd": "github-actions",
    "monitoring": "structured-logging",
    "packageManager": "uv",
    "environments": ["development", "test", "staging", "production"]
  },
  "agents": {
    "specialized": {
      "backend-developer": {
        "capabilities": ["api-development", "async-programming", "httpx", "fastapi"],
        "priority": "high"
      },
      "test-engineer": {
        "capabilities": ["pytest", "coverage-analysis", "test-automation", "mocking"],
        "priority": "high"
      },
      "security-analyst": {
        "capabilities": ["owasp-testing", "vulnerability-scanning", "security-automation"],
        "priority": "medium"
      },
      "performance-engineer": {
        "capabilities": ["load-testing", "benchmarking", "resource-monitoring"],
        "priority": "medium"
      },
      "devops-engineer": {
        "capabilities": ["docker", "ci-cd", "automation", "monitoring"],
        "priority": "medium"
      }
    }
  },
  "workflows": {
    "development": {
      "phases": ["specification", "pseudocode", "architecture", "implementation", "testing"],
      "methodology": "sparc-tdd",
      "parallelism": true
    },
    "testing": {
      "strategy": "comprehensive",
      "coverage": 85,
      "types": ["unit", "integration", "security", "performance"],
      "automation": true
    },
    "deployment": {
      "strategy": "multi-stage",
      "environments": ["test", "staging", "production"],
      "validation": true,
      "rollback": true
    }
  },
  "integration": {
    "python": {
      "version": "3.12",
      "packageManager": "uv",
      "virtualenv": true
    },
    "nodejs": {
      "version": "24.4.1",
      "packageManager": "npm"
    },
    "docker": {
      "multiStage": true,
      "optimization": true
    },
    "github": {
      "actions": true,
      "webhooks": true,
      "integration": true
    }
  }
}