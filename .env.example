# アプリ設定（Pydantic Settings準拠）
ENVIRONMENT=development
DEBUG=false

# API設定（ネスト: API__*）
API__BASE_URL=https://jsonplaceholder.typicode.com

# ログ設定（ネスト: LOG__*）
LOG__LEVEL=INFO

# セキュリティ設定（ネスト: SECURITY__*）
SECURITY__ALLOWED_HOSTS='["localhost","127.0.0.1"]'

# Sentry Configuration (Error Monitoring)
SENTRY__ENABLED="false"                               # Enable/disable Sentry error monitoring
SENTRY__ENVIRONMENT="development"                     # Environment name (development/testing/staging/production)
SENTRY__TRACES_SAMPLE_RATE="0.1"                      # Traces sampling rate (0.0-1.0)
SENTRY__PROFILES_SAMPLE_RATE="0.1"                    # Profiles sampling rate (0.0-1.0)
SENTRY__SEND_DEFAULT_PII="false"                      # Send personally identifiable information
SENTRY__DSN=""                                          # Required when SENTRY__ENABLED=true. Example: https://xxx@xxx.ingest.us.sentry.io/xxx

# Security Configuration
# SECURITY__API_KEY=""                                  # API authentication key (optional in dev, required in production/staging)
# SECURITY__JWT_SECRET=""                               # JWT signing secret (optional in dev, required in production/staging)

# Test Configuration
TEST__EXTERNAL_API_ENABLED="true"                     # Enable/disable integration tests that access external APIs (JSONPlaceholder)

# AI-Powered Code Search Tools（2種類のAPIキーが必要）
# - MORPH_API_KEY: morph-mcp MCPサーバー（AI検索、Claude Code Action CI用）
# - MXBAI_API_KEY: mgrep CLIツール（セマンティック検索、Bash経由）
# 両方とも任意。未設定時はそれぞれの機能がgraceful degradationで無効化

# morph-mcp (AI-Powered Code Search & Edit - MCP Server)
# Used by: Claude Code Action CI, local Claude Code via MCP
# How to get API key:
#   1. Visit: https://www.morphllm.com/
#   2. Create account and get API key from dashboard
# Documentation: https://docs.morphllm.com/mcpquickstart
# MORPH_API_KEY=your-morph-api-key-here

# mgrep (Semantic Code Search - CLI Tool)
# Used by: Claude Code local + CI via Bash(mgrep:*)
# Authentication method depends on environment:
#   - Local development: Use `mgrep login` (browser-based, recommended)
#   - CI/CD (GitHub Actions): Set this environment variable
# How to get API key:
#   1. Visit: https://www.mixedbread.ai/
#   2. Create account or login
#   3. Navigate to API Keys section
#   4. Generate new API key
# Usage:
#   - For local testing (optional): Copy this file to .env and set your key
#   - For CI/CD: Add MXBAI_API_KEY to GitHub Secrets (Settings → Secrets)
# Documentation: https://github.com/mixedbread-ai/mgrep
# MXBAI_API_KEY=your_api_key_here

# =============================================================================
# 4環境管理スキーム (docker-compose.yml 連携)
# =============================================================================
#
# このファイルはコミット対象のテンプレート（プレースホルダーのみ）。
# 実際の環境変数は環境ごとに以下を作成する:
#   .env.development / .env.testing / .env.staging / .env.production
# いずれも .gitignore 対象（.env* + !.env.example）。本ファイルからコピーして値を埋める。
#
# 切替方法（compose は ENVIRONMENT で読込ファイルを選択）:
#   docker compose up                                # → 既定 .env.development
#   ENVIRONMENT=staging docker compose up            # → .env.staging
#   ENVIRONMENT=production docker compose up         # → .env.production
#   docker compose --profile test run --rm test     # → .env.testing
#
# 環境名マッピング:
#   docker 命名(dev/test/demo/prod) → Pydantic Environment 値
#     dev   → development
#     test  → testing
#     demo  → staging   # Pydantic enum に "demo" は存在しないため staging に集約
#     prod  → production
#
# Pydantic 制約 (config/settings.py):
#   - staging / production では API__BASE_URL が https:// 必須
#   - staging / production では SECURITY__API_KEY または SECURITY__JWT_SECRET のいずれか必須
#   - ネスト区切り: "__" (例: API__BASE_URL は api.base_url にマッピング)
#
# =============================================================================
# 環境変数リファレンス (settings.py 由来の全フィールド)
# =============================================================================
# 既出フィールドは上記セクションを参照。以下は未網羅フィールド（全て任意、Pydantic 既定値適用）。

# --- アプリ基本 ---
# PROJECT_NAME="API Test Portfolio"
# VERSION="0.1.0"

# --- API 詳細 (ネスト: API__*) ---
# API__TIMEOUT="30.0"                                  # 1.0-300.0 秒
# API__RETRY_COUNT="3"                                 # 0-10
# API__RETRY_DELAY="1.0"                               # 0.1-60.0 秒
# API__MAX_CONNECTIONS="10"                            # 1-100
# API__USER_AGENT="API-Test-Portfolio/0.1.0"

# --- ログ詳細 (ネスト: LOG__*) ---
# LOG__FORMAT="json"                                   # console | json
# LOG__FILE=""                                         # 未設定でファイル出力なし
# LOG__MAX_SIZE="10485760"                             # 10MB
# LOG__BACKUP_COUNT="5"                                # 1-100
# LOG__CONSOLE_OUTPUT="true"

# --- セキュリティ詳細 (ネスト: SECURITY__*) ---
# SECURITY__RATE_LIMIT_REQUESTS="100"                  # >=1
# SECURITY__RATE_LIMIT_WINDOW="3600"                   # 秒、>=60
# SECURITY__ENABLE_CORS="false"

# --- テスト詳細 (ネスト: TEST__*) ---
# TEST__SLOW_TEST_THRESHOLD="5.0"                      # 秒
# TEST__MAX_CONCURRENT_REQUESTS="5"                    # 1-50
# TEST__PERFORMANCE_TEST_ENABLED="false"
# TEST__SECURITY_TEST_ENABLED="false"
# TEST__TEST_DATA_CLEANUP="true"

# --- SSRF Prevention ---
# ALLOWED_DOMAINS="jsonplaceholder.typicode.com,api.github.com,httpbin.org"
#   未設定時は config/settings.py の DEFAULT_ALLOWED_DOMAINS が適用される

