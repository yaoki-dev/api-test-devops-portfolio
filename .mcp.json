{
  "mcpServers": {
    "task-master-ai": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "task-master-ai"
      ],
      "env": {
        "TASK_MASTER_TOOLS": "get_tasks,get_task,add_task,update_task,add_subtask,update_subtask,remove_task,expand_task,expand_all,analyze_project_complexity,fix_dependencies,parse_prd,models"
      },
      "metadata": {
        "description": "Task management and workflow automation (optimized - 31 tools)",
        "version": "latest",
        "source": "npm",
        "optimization": "Custom tool selection - 30% token reduction"
      }
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "limited_serena",
        "--project",
        "/Users/yuta/Yuta/python/api-test-devops-portfolio"
      ]
    },
    "claude-flow": {
      "type": "stdio",
      "command": "/Users/yuta/.nvm/versions/node/v20.19.4/bin/npx",
      "args": [
        "claude-flow@alpha",
        "mcp",
        "start"
      ],
      "env": {}
    },
    "claude-flow-lite": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/Users/yuta/workspace/ruv-claude-flow/src/mcp/mcp-server-wrapper.js"
      ],
      "env": {
        "NODE_ENV": "production",
        "CLAUDE_FLOW_FALLBACK_PATH": "/Users/yuta/workspace/ruv-claude-flow/src/mcp/mcp-server.js",
        "CLAUDE_FLOW_DEBUG": "false"
      },
      "metadata": {
        "description": "Claude Flow Lite - Multi-agent workflow orchestration",
        "version": "2.7.0-lite.7",
        "source": "local-wrapper",
        "fallback": "enabled",
        "strategy": "npm-first -> local-fallback",
        "note": "Using local wrapper for fallback support (npm package integration pending)"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "metadata": {
        "description": "Sequential thinking MCP server (global setting also available)",
        "source": "npm"
      }
    },
    "obsidian-mcp-tools": {
      "command": "/Users/yuta/obsidian-vault/.obsidian/plugins/mcp-tools/bin/mcp-server",
      "args": [],
      "env": {
        "OBSIDIAN_API_KEY": "5e2e4eec3d3ccd1b7c4ba929bb0697046acf1b04013728063e76db3604549200"
      }
    },
    "ast-grep": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ],
      "env": {}
    }
  }
